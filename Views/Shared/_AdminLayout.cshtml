<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShopNest – Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary: #1a1a2e;
            --accent: #e94560;
            --gold: #f5a623;
            --sidebar-w: 240px;
            --text-muted: #7a7a8c;
            --success: #2ecc71;
            --warning: #f39c12;
            --info: #3498db;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans',sans-serif;
            background: #f0eff4;
            color: var(--primary);
            margin: 0;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--primary);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow-y: auto;
        }

        .sidebar-brand {
            padding: 22px 20px 18px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }

            .sidebar-brand .brand-name {
                font-family: 'Playfair Display',serif;
                font-size: 1.4rem;
                color: #fff;
            }

                .sidebar-brand .brand-name span {
                    color: var(--accent);
                }

            .sidebar-brand .brand-badge {
                font-size: .65rem;
                background: var(--accent);
                color: #fff;
                padding: 2px 8px;
                border-radius: 10px;
                margin-left: 6px;
                vertical-align: middle;
            }

        .nav-section-label {
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,.35);
            padding: 16px 20px 6px;
            font-weight: 600;
        }

        .sidebar .nav-link {
            color: rgba(255,255,255,.65);
            padding: 10px 20px;
            border-radius: 0;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: .9rem;
            font-weight: 500;
            transition: all .2s;
            border-left: 3px solid transparent;
        }

            .sidebar .nav-link:hover {
                color: #fff;
                background: rgba(255,255,255,.06);
            }

            .sidebar .nav-link.active {
                color: #fff;
                background: rgba(233,69,96,.15);
                border-left-color: var(--accent);
            }

            .sidebar .nav-link i {
                font-size: 1rem;
                width: 20px;
                text-align: center;
            }

        .sidebar-footer {
            margin-top: auto;
            padding: 16px 20px;
            border-top: 1px solid rgba(255,255,255,.08);
        }

        .admin-avatar {
            width: 36px;
            height: 36px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .9rem;
        }

        /* MAIN CONTENT */
        .main-content {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* TOP BAR */
        .topbar {
            background: #fff;
            padding: 14px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #e8e8f0;
            position: sticky;
            top: 0;
            z-index: 500;
        }

            .topbar h4 {
                font-family: 'Playfair Display',serif;
                font-size: 1.3rem;
                margin: 0;
            }

            .topbar .search-input {
                border: 1px solid #e8e8f0;
                border-radius: 8px;
                padding: 8px 14px;
                font-size: .88rem;
                font-family: 'DM Sans',sans-serif;
                outline: none;
                width: 240px;
            }

                .topbar .search-input:focus {
                    border-color: var(--accent);
                }

        .notif-btn {
            position: relative;
            background: none;
            border: none;
            padding: 6px 10px;
            cursor: pointer;
            color: var(--text-muted);
        }

        .notif-badge {
            position: absolute;
            top: 0;
            right: 2px;
            background: var(--accent);
            color: #fff;
            border-radius: 50%;
            width: 16px;
            height: 16px;
            font-size: .6rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* PAGE BODY */
        .page-body {
            padding: 28px;
            flex: 1;
        }

        /* STAT CARDS */
        .stat-card {
            background: #fff;
            border-radius: 12px;
            padding: 22px;
            border: 1px solid #e8e8f0;
            position: relative;
            overflow: hidden;
        }

            .stat-card::after {
                content: '';
                position: absolute;
                right: -20px;
                top: -20px;
                width: 90px;
                height: 90px;
                border-radius: 50%;
                opacity: .07;
            }

            .stat-card.revenue::after {
                background: var(--success);
            }

            .stat-card.orders::after {
                background: var(--info);
            }

            .stat-card.customers::after {
                background: var(--gold);
            }

            .stat-card.products::after {
                background: var(--accent);
            }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            margin-bottom: 14px;
        }

        .stat-value {
            font-family: 'Playfair Display',serif;
            font-size: 1.9rem;
            font-weight: 700;
        }

        .stat-label {
            font-size: .82rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .stat-change {
            font-size: .78rem;
            font-weight: 600;
        }

            .stat-change.up {
                color: var(--success);
            }

            .stat-change.down {
                color: var(--accent);
            }

        /* SECTION CARD */
        .section-card {
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e8e8f0;
            overflow: hidden;
        }

        .section-card-header {
            padding: 18px 22px;
            border-bottom: 1px solid #e8e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .section-card-header h6 {
                font-weight: 700;
                margin: 0;
                font-size: 1rem;
            }

        .section-card-body {
            padding: 22px;
        }

        /* TABLE */
        .admin-table {
            width: 100%;
            border-collapse: collapse;
        }

            .admin-table th {
                background: #f8f7fb;
                color: var(--text-muted);
                font-size: .78rem;
                text-transform: uppercase;
                letter-spacing: .5px;
                padding: 10px 16px;
                border-bottom: 1px solid #e8e8f0;
                font-weight: 600;
            }

            .admin-table td {
                padding: 13px 16px;
                border-bottom: 1px solid #f0eff4;
                font-size: .9rem;
                vertical-align: middle;
            }

            .admin-table tr:last-child td {
                border-bottom: none;
            }

            .admin-table tr:hover td {
                background: #fafafa;
            }

        /* BADGES */
        .badge-status {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: .72rem;
            font-weight: 600;
        }

        .badge-Pending {
            background: #fff3cd;
            color: #856404;
        }

        .badge-Processing {
            background: #cfe2ff;
            color: #084298;
        }

        .badge-Shipped {
            background: #d1ecf1;
            color: #0c5460;
        }

        .badge-Completed {
            background: #d4edda;
            color: #155724;
        }

        .badge-Cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-Active {
            background: #d4edda;
            color: #155724;
        }

        .badge-Inactive {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-Low {
            background: #fff3cd;
            color: #856404;
        }

        /* PRODUCT THUMB */
        .prod-thumb {
            width: 40px;
            height: 40px;
            background: #f0ede8;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
        }

        /* ACTION BUTTONS */
        .btn-tbl {
            border: none;
            background: none;
            padding: 4px 8px;
            border-radius: 5px;
            cursor: pointer;
            font-size: .85rem;
        }

        .btn-tbl-edit {
            color: var(--info);
        }

            .btn-tbl-edit:hover {
                background: #e8f4fd;
            }

        .btn-tbl-del {
            color: var(--accent);
        }

            .btn-tbl-del:hover {
                background: #fdecea;
            }

        .btn-tbl-view {
            color: var(--text-muted);
        }

            .btn-tbl-view:hover {
                background: #f0eff4;
            }

        /* QUICK STATS BAR */
        .quick-stat {
            text-align: center;
            padding: 14px 10px;
        }

            .quick-stat .val {
                font-family: 'Playfair Display',serif;
                font-size: 1.5rem;
                font-weight: 700;
            }

            .quick-stat .lbl {
                font-size: .75rem;
                color: var(--text-muted);
            }

        /* TABS */
        .admin-tabs {
            border-bottom: 2px solid #e8e8f0;
        }

            .admin-tabs .nav-link {
                border: none;
                color: var(--text-muted);
                font-weight: 500;
                padding: 10px 18px;
                font-size: .9rem;
            }

                .admin-tabs .nav-link.active {
                    color: var(--accent);
                    border-bottom: 2px solid var(--accent);
                    margin-bottom: -2px;
                }

        /* MODAL */
        .modal-header {
            border-bottom: 1px solid #e8e8f0;
        }

        .modal-title {
            font-family: 'Playfair Display',serif;
            font-size: 1.2rem;
        }

        .form-label {
            font-size: .86rem;
            font-weight: 500;
        }

        .form-control, .form-select {
            border: 1px solid #e0ddd8;
            border-radius: 7px;
            font-family: 'DM Sans',sans-serif;
            font-size: .9rem;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(233,69,96,.1);
            }

        /* CHART PLACEHOLDER */
        .chart-placeholder {
            background: #f8f7fb;
            border-radius: 10px;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: .9rem;
            flex-direction: column;
            gap: 6px;
        }

        /* MINI BARS */
        .mini-bar {
            height: 8px;
            border-radius: 4px;
            background: #e8e8f0;
            overflow: hidden;
        }

        .mini-bar-fill {
            height: 100%;
            border-radius: 4px;
            background: var(--accent);
        }

        /* MOBILE SIDEBAR */
        .sidebar {
            transition: transform .3s ease;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.5);
            z-index: 999;
        }

            .sidebar-overlay.show {
                display: block;
            }

        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            color: var(--primary);
            font-size: 1.4rem;
            cursor: pointer;
            padding: 4px 8px;
        }

        @@media (max-width: 900px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .hamburger-btn { display: block; }
            .topbar { padding: 12px 16px; }
        }

    </style>
</head>
<body>

    <!-- MOBILE OVERLAY -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-name">Shop<span>Nest</span><span class="brand-badge">ADMIN</span></div>
            <div style="font-size:.75rem;color:rgba(255,255,255,.4);margin-top:3px;">Management Panel v1.0</div>
        </div>

        <div class="nav-section-label">Main</div>
        <a asp-action="Index" asp-controller="Admin" class="nav-link " onclick="showSection('dashboard')"><i class="bi bi-grid-1x2"></i>Dashboard</a>
        <a asp-action="Orders" asp-controller="Admin" class="nav-link"><i class="bi bi-bag-check"></i>Orders <span class="ms-auto badge" style="background:var(--accent);font-size:.65rem;">12</span></a>
        <a asp-action="Products" asp-controller="Admin" class="nav-link"><i class="bi bi-box-seam"></i>Products</a>
        <a asp-action="customers" asp-controller="Admin" class="nav-link"><i class="bi bi-people"></i>Customers</a>

        <div class="nav-section-label">Store</div>
        <a asp-action="Categories" asp-controller="Admin" class="nav-link" onclick="showSection('categories')"><i class="bi bi-tags"></i>Categories</a>


        <div class="sidebar-footer">
            <div class="d-flex align-items-center gap-2">
                <div class="admin-avatar">A</div>
                <div>
                    <div style="color:#fff;font-size:.85rem;font-weight:600;">Admin User</div>
                </div>
            </div>
            <a asp-controller="Account" asp-action="Logout" class="d-block mt-3 text-center" style="color:rgba(255,255,255,.45);font-size:.78rem;text-decoration:none;">
                <i  class="bi bi-box-arrow-left me-1"></i>Logout
            </a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- TOPBAR -->
        <div class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="hamburger-btn" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
                <h4 id="pageTitle" style="margin:0;font-family:'Playfair Display',serif;font-size:1.3rem;">@(ViewData["MainKey"] ?? "Dashboard")</h4>
            </div>
            <div class="d-flex align-items-center gap-3">
                <a asp-action="Index" asp-controller="Home" class="btn btn-sm btn-outline-secondary px-3" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i>View Store</a>
            </div>
        </div>

        <!-- PAGE BODY -->
        <div class="page-body">
            @RenderBody()
        </div>  
       <!-- end page-body -->
    </div><!-- end main-content -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
          document.getElementById("sidebar").classList.toggle("open");
          document.getElementById("sidebarOverlay").classList.toggle("show");
        }
        function closeSidebar() {
          document.getElementById("sidebar").classList.remove("open");
          document.getElementById("sidebarOverlay").classList.remove("show");
        }

        const sections = ["dashboard","products","orders","customers","categories","coupons"];
        const titles = { dashboard:"Dashboard", products:"Products", orders:"Orders", customers:"Customers", categories:"Categories", coupons:"Coupons" };

        function showSection(name) {
          sections.forEach(s => {
            const el = document.getElementById("section-" + s);
            if (el) el.style.display = (s === name) ? "block" : "none";
          });
          document.getElementById("pageTitle").textContent = titles[name] || name;
          document.querySelectorAll(".sidebar .nav-link").forEach(l => l.classList.remove("active"));
          closeSidebar();
        }

        document.querySelectorAll(".sidebar .nav-link").forEach(link => {
          link.addEventListener("click", function() {
            document.querySelectorAll(".sidebar .nav-link").forEach(l => l.classList.remove("active"));
            this.classList.add("active");
          });
        });
    </script>
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
    $(document).ready(function () {
        var currentUrl = window.location.pathname.toLowerCase();


        $('.sidebar a, .nav a').each(function () {
            var linkUrl = $(this).attr('href');

            if (linkUrl) {
                linkUrl = linkUrl.toLowerCase();

                if (currentUrl === linkUrl || currentUrl.startsWith(linkUrl + '/')) {

                    $('.sidebar a, .nav a').removeClass('active');

                    $(this).addClass('active');


                }
            }
        });
    });
</script>