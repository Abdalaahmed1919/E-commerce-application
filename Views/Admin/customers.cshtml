@model List<AppUser>
@{
    ViewData["Title"] = "Customers";
    ViewData["MainKey"] = "Customers";
}

<div id="section-customers">
    <div class="section-card mb-3 p-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <input type="text" id="searchCustomer" class="form-control form-control-sm" placeholder="Search by name or email..." />
            </div>
            <div class="col-md-2">
                <button type="button" id="btnFilterCustomer" class="btn btn-sm w-100" style="background:var(--accent);color:#fff;border:none;">Filter</button>
            </div>
        </div>
    </div>
    </div>
    <div class="section-card">
        <div style="overflow-x:auto;">
            <table class="admin-table">
                <thead><tr><th>Customer</th><th>Email</th><th>Phone</th><th>Orders</th><th>Total Spent</th><th>Joined</th><th>Actions</th></tr></thead>
            <tbody id="customersTableBody">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:34px; height:34px; background:#f0ede8; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.85rem;">
                                        @(string.Join("", (user.Name ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper())
                                    </div>
                                    <span style="font-size:.88rem; font-weight:600;">
                                        @user.Name
                                    </span>
                                </div>
                            </td>

                            <td style="font-size:.85rem;">
                                <span style="font-size:.88rem; font-weight:600;">
                                    @user.Email
                                </span>
                            </td>

                            <td style="font-size:.85rem;">
                                @user.PhoneNumber
                            </td>

                            <td>
                                @user.Orders.Count
                            </td>


                            <td style="font-weight:600; color:var(--success);">
                                @user.Orders.Where(o => o.Status.ToString() != "Cancelled").Sum(o => o.TotalPrice)
                            </td>

                            <td style="font-size:.82rem;">
                                @user.CreatedAt.ToString("MMM/dd//yyyy")
                            </td>
                            <td>
                                <button class="btn-tbl btn-tbl-del delete-user-btn" data-id="@user.Id">
                                    <i class="bi bi-trash3"></i>
                                </button>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


@section Scripts {
    <script>

            $(document).on('click', '.delete-user-btn', function () {

            var userId = $(this).data('id');
            var button = $(this);
            var row = button.closest('tr'); 

            if (confirm("هل أنت متأكد إنك عايز تمسح العميل ده؟")) {

                $.ajax({
                    url: '/Admin/DeleteCustomer', 
                    type: 'POST',
                    data: { id: userId },
                    success: function () {
                        row.fadeOut(400, function() {
                            $(this).remove();
                        });
                    },
                    error: function (xhr) {
                        alert("حصل خطأ ومش قادرين نمسح العميل ده!");
                        console.log(xhr.responseText);
                    }
                });
            }
        });

            $('#btnFilterCustomer').on('click', function () {
            var searchValue = $('#searchCustomer').val();

            $.ajax({
                url: '/Admin/FilterCustomers', 
                type: 'GET',
                data: { search: searchValue },
                success: function (result) {
                    $('#customersTableBody').html(result);
                },
                error: function () {
                    alert("حصل مشكلة في الفلترة!");
                }
            });
        });
    </script>
}