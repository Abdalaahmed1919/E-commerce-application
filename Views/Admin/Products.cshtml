@model ProductsAndOrderItemsIncludingCatogry;
@{
    ViewData["Title"] = "Products";
    ViewData["MainKey"] = "Products";
}

<div id="section-products">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div></div>
        <button class="btn btn-sm px-4" style="background:var(--accent);color:#fff;border:none;border-radius:7px;" data-bs-toggle="modal" data-bs-target="#addProductModal">
            <i class="bi bi-plus-lg me-2"></i>Add Product
        </button>
    </div>

    <!-- Filters -->
    <div class="section-card mb-3 p-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-4"><input type="text" id="searchFilter" class="form-control form-control-sm" placeholder="Search products..." /></div>

            <div class="col-md-2">
                <select id="categoryFilter" class="form-select form-select-sm">
                    <option value="">All Categories</option>
                    @foreach (var item in Model.Categories)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <select id="statusFilter" class="form-select form-select-sm">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Out Of Stock">Out Of Stock</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" id="btnFilter" class="btn btn-sm btn-outline-secondary w-100">Filter</button>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div style="overflow-x:auto;">
            <table class="admin-table">
                <thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Sales</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody id="tbody">
                    @foreach (var product in Model.Products)
                    {
                        var currentSales = Model.OrderItem
                        .Where(oi => oi.ProductId == product.Id)
                        .Sum(oi => oi.Quantity);


                        <tr>
                            <td><div class="d-flex align-items-center gap-2">
                                    <div class="prod-thumb"><img src="@product.ImageUrl" style="width: 21px;" alt="Alternate Text" /></div>
                                    <div>
                                        <div style="font-weight:600;font-size:.88rem;">@product.Name</div>
                                    </div>
                                </div>
                            </td>
                            <td>@product.Category.Name</td>
                            <td>@product.Price</td>
                            <td><span style="color:var(--success);font-weight:600;">@product.Stock</span></td>
                            <td>@currentSales</td>
                            @if (product.Stock == 0)
                            {
                                <td><span class="badge-status badge-active">Out Of Stock</span></td>
                            } else
                            {
                                
                                <td><span class="badge-status badge-active">Active</span></td>
                            }
        
                            <td><button class="btn-tbl btn-tbl-edit btn-edit-product" data-id="@product.Id">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button data-id="@product.Id" class="deletProduct btn-tbl btn-tbl-del"><i class="bi bi-trash3"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="AddProduct" asp-controller="Admin" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="@Model.NewProduct.Name" class="form-label">Product Name *</label>
                            <input asp-for="@Model.NewProduct.Name" class="form-control" placeholder="e.g. Premium Running Shoes" required />
                            <span asp-validation-for="@Model.NewProduct.Name"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="@Model.NewProduct.Description" class="form-label">Description</label>
                            <textarea asp-for="@Model.NewProduct.Description" class="form-control" rows="3" placeholder="Product description..."></textarea>
                            <span asp-validation-for="@Model.NewProduct.Description"></span>

                        </div>
                        <div class="col-md-4">
                            <label asp-for="@Model.NewProduct.Price" class="form-label">Price *</label>
                            <input asp-for="@Model.NewProduct.Price" step="0.01" class="form-control" placeholder="0.00" required />
                            <span asp-validation-for="@Model.NewProduct.Price"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="@Model.NewProduct.Stock" class="form-label">Stock Quantity *</label>
                            <input asp-for="@Model.NewProduct.Stock" class="form-control" placeholder="0" required />
                            <span asp-validation-for="@Model.NewProduct.Stock"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Category *</label>
                            <select asp-for="@Model.NewProduct.CategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))" required>
                                <option value="">Select category...</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="@Model.NewProduct.ImageUrl" class="form-label">Product Image</label>
                            <input asp-for="@Model.NewProduct.ImageUrl" class="form-control" />
                            <span asp-validation-for="@Model.NewProduct.ImageUrl"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" style="background:var(--accent);color:#fff;border:none;">Save Product</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="EditProduct" asp-controller="Admin" method="post" enctype="multipart/form-data">

                <input type="hidden" name="Id" id="editProdId" />
                <input type="hidden" name="ImageUrl" id="editProdImageUrl" />

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Product Name *</label>
                            <input type="text" name="Name" id="editProdName" class="form-control" required />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea name="Description" id="editProdDesc" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Price *</label>
                            <input  type="number"  name="Price" id="editProdPrice" step="0.01" class="form-control" required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Stock Quantity *</label>
                            <input type="number" name="Stock" id="editProdStock" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Category *</label>
                            <select name="CategoryId" id="editProdCategory" class="form-select" required>
                                <option value="">Select category...</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Update Product Image</label>
                            <input type="text" name="ImageFile" class="form-control" accept="image/*" />
                            <div class="text-muted mt-1" style="font-size: 0.8rem;">Leave empty if you don't want to change the current image.</div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" style="background:var(--accent);color:#fff;border:none;">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.deletProduct', function () {

            var productId = $(this).data('id');
            var button = $(this); 
            var row = button.closest('tr'); 

            if (confirm("هل أنت متأكد إنك عايز تمسح المنتج ده؟")) {

                $.ajax({
                    url: '/Admin/DeletProduct', 
                    type: 'POST', 
                    data: {
                        id: productId
                    },
                    success: function(result) {
                        row.fadeOut(400, function() {
                            $(this).remove();
                        });
                    },
                    error: function(xhr) {
                        alert("حدث خطأ أثناء الحذف!");
                        console.log("Error: " + xhr.responseText);
                    }
                });

            }
        });

        $(document).on('click', '.btn-edit-product', function () {

            var productId = $(this).data('id');

            // 2. بنروح للكنترولر نجيب الداتا
            $.ajax({
                url: '/Admin/GetProductForEdit',
                type: 'GET',
                data: { id: productId },
                success: function (data) {

                    $('#editProdId').val(data.id);
                    $('#editProdName').val(data.name);
                    $('#editProdDesc').val(data.description);
                    $('#editProdPrice').val(data.price);
                    $('#editProdStock').val(data.stock);
                    $('#editProdCategory').val(data.categoryId);
                    $('#editProdImageUrl').val(data.imageUrl);

                    $('#editProductModal').modal('show');
                },
                error: function (xhr) {
                    alert("حصلت مشكلة واحنا بنجيب بيانات المنتج!");
                    console.log(xhr.responseText);
                }
            });

        });
 
         $('#btnFilter').on('click', function () {

            var searchValue = $('#searchFilter').val();
            var categoryValue = $('#categoryFilter').val();
            var statusValue = $('#statusFilter').val();
            var tableBody = $('#tbody');
           
            $.ajax({
                url: '/Admin/FilterProducts',
                type: 'GET',
                data: {
                    search: searchValue,
                    categoryId: categoryValue,
                    Status: statusValue
                },
                success: function (result) {    

                    tableBody.html(result);



                },
                error: function () {
                    alert("حصل مشكلة في الفلترة!");
                }
            });
        });
    </script>
}