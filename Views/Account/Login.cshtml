@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

 <link href="~/css/Login.css" rel="stylesheet" />
<body>

    <div class="auth-wrapper">
        <div class="auth-left d-none d-md-flex">
            <div style="max-width:380px;position:relative;z-index:1;">
                <div style="font-size:3rem;margin-bottom:16px;">🛍️</div>
                <h2>Welcome Back to <span>ShopNest</span></h2>
                <p class="mt-3 mb-4">Your favorite shopping destination. Sign in to access your orders, wishlist, and exclusive deals.</p>
                <div class="feature-item">
                    <div class="feature-icon">🚀</div>
                    <div><strong>Fast Checkout</strong><div style="font-size:.83rem;color:rgba(255,255,255,.6);margin-top:2px;">Save your info for lightning-fast future purchases</div></div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">❤️</div>
                    <div><strong>Your Wishlist</strong><div style="font-size:.83rem;color:rgba(255,255,255,.6);margin-top:2px;">Save items and get notified on price drops</div></div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">📦</div>
                    <div><strong>Order Tracking</strong><div style="font-size:.83rem;color:rgba(255,255,255,.6);margin-top:2px;">Real-time updates on all your deliveries</div></div>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <div class="auth-card">
                <div class="auth-title">Sign In</div>
                <div class="auth-subtitle">Don't have an account? <a asp-action="Register" asp-controller="Account" class="link-accent">Create one free</a></div>

                <div asp-validation-summary="ModelOnly"></div>

                <form asp-action="SaveLogin" asp-controller="Account" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="john@example.com" />
                        <span asp-validation-for="Email"></span>
                    </div>

                    <div class="mb-2">
                        <label asp-for="Password" class="form-label">Password</label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" id="pwd" placeholder="Enter your password" />
                        </div>
                        <span asp-validation-for="Password"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 mt-1">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" id="remember" />
                            <label asp-for="RememberMe" class="form-check-label" style="font-size:.85rem;">Remember me</label>
                        </div>
                    </div>

                    <button type="submit" class="btn-login">Sign In <i class="bi bi-arrow-right ms-2"></i></button>
                </form>

                <div class="mt-4 text-center" style="font-size:.83rem;color:var(--text-muted);">
                    <i class="bi bi-shield-check me-1"></i>Your data is safe and secure with us.
                </div>

                <hr style="border-color:#ececec;margin:20px 0 14px;" />
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>