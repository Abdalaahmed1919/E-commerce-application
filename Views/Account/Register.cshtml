@model RegisterViewModel;
@{
    ViewData["Title"] = "Register";
}

<style>
    :root {
        --primary: #1a1a2e;
        --accent: #e94560;
        --light-bg: #f8f7f4;
        --text-muted: #7a7a8c;
    }

    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans',sans-serif;
        background: var(--light-bg);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .auth-wrapper {
        flex: 1;
        display: flex;
    }

    .auth-left {
        background: linear-gradient(135deg, #0f3460 0%, #16213e 60%, var(--primary) 100%);
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 50px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

        .auth-left::before {
            content: '';
            position: absolute;
            top: -80px;
            left: -80px;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(233,69,96,.2) 0%, transparent 70%);
            border-radius: 50%;
        }

        .auth-left h2 {
            font-family: 'Playfair Display',serif;
            font-size: 2.2rem;
            line-height: 1.2;
        }

            .auth-left h2 span {
                color: var(--accent);
            }

    .perk {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
        font-size: .9rem;
    }

        .perk i {
            color: var(--accent);
            font-size: 1rem;
        }

    .auth-right {
        width: 520px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 50px;
        overflow-y: auto;
    }

    .auth-card {
        width: 100%;
    }

    .auth-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .auth-subtitle {
        color: var(--text-muted);
        font-size: .9rem;
        margin-bottom: 24px;
    }

    .form-label {
        font-size: .88rem;
        font-weight: 500;
        color: var(--primary);
        margin-bottom: 4px;
    }

    .form-control {
        border: 1.5px solid #e0ddd8;
        border-radius: 8px;
        font-family: 'DM Sans',sans-serif;
        font-size: .92rem;
        padding: 10px 14px;
        transition: border-color .2s;
    }

        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(233,69,96,.12);
        }

    .input-group .form-control {
        border-right: none;
    }

    .input-group .btn {
        border: 1.5px solid #e0ddd8;
        border-left: none;
        background: #fff;
        color: var(--text-muted);
        border-radius: 0 8px 8px 0;
    }

    .strength-bar {
        height: 4px;
        border-radius: 4px;
        transition: all .3s;
        margin-top: 6px;
    }

    .btn-register {
        background: var(--accent);
        color: #fff;
        border: none;
        width: 100%;
        padding: 13px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        transition: opacity .2s;
        margin-top: 25px;
    }

        .btn-register:hover {
            opacity: .88;
        }

    .link-accent {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
    }

        .link-accent:hover {
            text-decoration: underline;
        }

    @@media(max-width:768px) {
        .auth-left {
            display: none;
        }

        .auth-right {
            width: 100%;
            padding: 40px 24px;
        }
    }

    /* === التنسيقات الجديدة الخاصة بالـ Validation === */
    .field-validation-error {
        color: #dc3545; /* لون أحمر واضح */
        font-size: 0.8rem;
        font-weight: 500;
        margin-top: 5px;
        display: block; /* عشان ينزل في سطر لوحده تحت الحقل */
    }

    .validation-summary-errors {
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        padding: 12px 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 0.85rem;
        border: 1px solid rgba(220, 53, 69, 0.2);
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 20px;
        }
</style>

<body>

    <div class="auth-wrapper">
        <div class="auth-left d-none d-md-flex">
            <div style="max-width:360px;position:relative;z-index:1;">
                <div style="font-size:3rem;margin-bottom:16px;">✨</div>
                <h2>Join <span>ShopNest</span> Today</h2>
                <p style="color:rgba(255,255,255,.7);margin-top:12px;margin-bottom:28px;font-size:.95rem;">Create your free account and unlock a world of amazing products and exclusive member deals.</p>
                <div class="perk"><i class="bi bi-check-circle-fill"></i> Free & fast shipping on orders over $50</div>
                <div class="perk"><i class="bi bi-check-circle-fill"></i> Exclusive member-only discounts</div>
                <div class="perk"><i class="bi bi-check-circle-fill"></i> Easy returns within 30 days</div>
                <div class="perk"><i class="bi bi-check-circle-fill"></i> Priority customer support</div>
                <div class="perk"><i class="bi bi-check-circle-fill"></i> Earn points on every purchase</div>
                <div class="mt-4 p-3" style="background:rgba(255,255,255,.08);border-radius:10px;border:1px solid rgba(255,255,255,.12);">
                    <div style="font-size:.83rem;color:rgba(255,255,255,.6);margin-bottom:6px;">Trusted by</div>
                    <div style="font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;">50,000+</div>
                    <div style="font-size:.83rem;color:rgba(255,255,255,.6);">happy shoppers worldwide</div>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <div class="auth-card">
                <div class="auth-title">Create Account</div>
                <div class="auth-subtitle">Already have an account? <a asp-action="Login" asp-controller="Account" class="link-accent">Sign in</a></div>

                <div asp-validation-summary="ModelOnly"></div>

                <form asp-action="SaveRegister" asp-controller="Account" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">First Name *</label>
                            <input asp-for="FirstName" class="form-control" placeholder="John" />
                            <span asp-validation-for="FirstName"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Last Name *</label>
                            <input asp-for="LastName" class="form-control" placeholder="Doe" />
                            <span asp-validation-for="LastName"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Email" class="form-label">Email Address *</label>
                            <input asp-for="Email" class="form-control" placeholder="john@example.com" />
                            <span asp-validation-for="Email"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+1 (555) 000-0000" />
                            <span asp-validation-for="PhoneNumber"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Password" class="form-label">Password *</label>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control" id="pwd" placeholder="Min. 8 characters" oninput="checkStrength(this.value)" />
                            </div>
                            <span asp-validation-for="Password"></span>

                            <div class="strength-bar bg-secondary" id="strengthBar" style="width:0%;"></div>
                            <div id="strengthText" style="font-size:.75rem;color:var(--text-muted);margin-top:3px;"></div>
                        </div>

                        <div class="col-12">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password *</label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" class="form-control" id="cpwd" placeholder="Repeat your password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword"></span>
                        </div>

                        <div class="col-12 mt-1">
                            <button type="submit" class="btn-register">Create My Account <i class="bi bi-arrow-right ms-2"></i></button>
                        </div>
                    </div>
                </form>

                <div class="text-center mt-3" style="font-size:.8rem;color:var(--text-muted);">
                    <i class="bi bi-shield-check me-1"></i>Your information is encrypted and secure.
                </div>
            </div>
        </div>
    </div>


</body>

