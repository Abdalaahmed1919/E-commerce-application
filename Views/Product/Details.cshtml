@model Simple_E_commers_App.Models.Product

@{
    ViewData["Title"] = Model.Name + " - ShopNest";
}

<div class="container py-5 mt-4">
    <a href="/Product/Index" class="text-decoration-none text-muted mb-4 d-inline-block transition-link">
        <i class="bi bi-arrow-left me-2"></i> العودة للمنتجات
    </a>

    <div class="row gx-lg-5 align-items-center">
        <div class="col-lg-6 mb-5 mb-lg-0">
            <div class="bg-light rounded-4 p-4 text-center shadow-sm" style="height: 500px; display: flex; align-items: center; justify-content: center;">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height: 100%; object-fit: contain;" onerror="this.src='https://images.unsplash.com/photo-1505740420928-5e560c06d30e?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80'" />
            </div>
        </div>

        <div class="col-lg-6">
            <h6 class="text-uppercase text-danger tracking-wide fw-bold mb-2">ShopNest Premium</h6>
            <h1 class="fw-bolder display-5 mb-3">@Model.Name</h1>
            
            <div class="fs-2 fw-bold text-dark mb-4">
                $@Model.Price
            </div>

            <p class="text-muted lh-lg mb-4 fs-5" style="max-width: 85%;">
                @Model.Description
                @(string.IsNullOrEmpty(Model.Description) ? "تصميم عصري بخامات عالية الجودة لضمان أفضل تجربة استخدام. يتميز بالبساطة والأناقة ليناسب ذوقك الرفيع." : "")
            </p>

            <hr class="my-4 text-muted">

            @* <form action="/Cart/AddToCart" method="post" class="d-flex align-items-center gap-3"> *@
                <input type="hidden" name="productId" value="@Model.Id" />
@if (Model.Stock > 0)
    {
        <button type="button" class="btn btn-dark btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg hover-scale add-to-cart-btn" data-id="@Model.Id">
            إضافة للسلة <i class="bi bi-bag-plus ms-2"></i>
        </button>
    }
    else
    {
        <div class="alert alert-danger mb-0 w-100 rounded-pill text-center fw-bold" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i> نفذت الكمية (Out of Stock)
        </div>
    }
            @* </form> *@

            <div class="mt-4 pt-3 d-flex gap-4 text-muted small fw-bold">
                <span><i class="bi bi-shield-check text-success fs-5 align-middle me-1"></i> ضمان الجودة</span>
                <span><i class="bi bi-truck text-primary fs-5 align-middle me-1"></i> شحن سريع</span>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-wide { letter-spacing: 2px; }
    .transition-link { transition: color 0.3s ease; }
    .transition-link:hover { color: #000 !important; }
    .hover-scale { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .hover-scale:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important; }
</style>
<script src="/lib/jquery/dist/jquery.min.js"></script>
<script>
       $(document).ready(function () {
          $(document).on('click', '.add-to-cart-btn', function (e) {
              e.preventDefault();

              var btn = $(this);
              var pId = btn.data('id');

              $.ajax({
                      url: '/Product/AddToCart',
                    type: 'POST',
                    data: { productId: pId },
                  success: function (response) {
                      if (response.success) {

                          alert(response.message);

                      }
                  },
                  error: function (xhr) {
                      if (xhr.status === 401) {
                          window.location.href = '/Account/Login';
                      } else {
                          alert("حصلت مشكلة واحنا بنضيف المنتج!");
                      }
                  }
              });
          });
      });
</script>