@model IEnumerable<Simple_E_commers_App.Models.Order>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-bag-check me-2"></i> طلباتي السابقة</h2>
        <a href="/Product/Index" class="btn btn-outline-dark">استكمال التسوق</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded-4 bg-light">
            <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">لم تقم بإجراء أي طلبات حتى الآن.</h4>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-4 bg-white p-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>رقم الطلب</th>
                        <th>التاريخ</th>
                        <th>إجمالي المبلغ</th>
                        <th>حالة الطلب</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@order.Id</td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-success fw-bold">$@order.TotalPrice</td>
                            <td>
                                @if (order.Status.ToString() == "Pending")
                                {
                                    <span class="badge rounded-pill bg-warning text-dark px-3">قيد الانتظار</span>
                                }
                                else if (order.Status.ToString() == "Shipped")
                                {

                                    <span class="badge rounded-pill bg-info text-white px-3">تم الشحن</span>
                                }
                                else if (order.Status.ToString() == "Delivered")
                                {

                                    <span class="badge rounded-pill bg-success text-white px-3">تم التوصيل</span>
                                }
                                else
                                {

                                    <span class="badge rounded-pill bg-secondary text-white px-3">@order.Status</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>