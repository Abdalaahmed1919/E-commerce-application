@model RoleViewModel

@{
    ViewData["Title"] = "Add New Role";
}

<link href="~/css/Role.css" rel="stylesheet" />

<body>

    <div class="auth-wrapper">
        <div class="auth-left d-none d-md-flex">
            <div style="max-width:380px;position:relative;z-index:1;">
                <div style="font-size:3rem;margin-bottom:16px;">🛡️</div>
                <h2>ShopNest <span>Admin</span></h2>
                <p class="mt-3 mb-4">Secure and manage your platform. Create specific roles to control access levels across the system.</p>
                <div class="feature-item">
                    <div class="feature-icon">🔐</div>
                    <div><strong>Access Control</strong><div style="font-size:.83rem;color:rgba(255,255,255,.6);margin-top:2px;">Define exactly what each user can see and do</div></div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">⚡</div>
                    <div><strong>Easy Management</strong><div style="font-size:.83rem;color:rgba(255,255,255,.6);margin-top:2px;">Assign or revoke roles with a single click</div></div>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <div class="auth-card">
                <div class="auth-title">Add New Role</div>
                <div class="auth-subtitle">Create a new permission level for users.</div>

                <div asp-validation-summary="ModelOnly"></div>

                <form asp-action="AddRole" method="post">
                    <div class="mb-4">
                        <label asp-for="RoleName" class="form-label">Role Name <span class="text-danger">*</span></label>
                        <input asp-for="RoleName" class="form-control" placeholder="e.g. Moderator, Editor, Seller..." />
                        <span asp-validation-for="RoleName"></span>
                    </div>

                    <button type="submit" class="btn-login mb-3">Create Role <i class="bi bi-shield-lock ms-2"></i></button>

                    <div class="text-center">
                        <a asp-action="Index" class="link-accent" style="font-size: .9rem;"><i class="bi bi-arrow-left me-1"></i> Back to Roles List</a>
                    </div>
                </form>

                <hr style="border-color:#ececec;margin:30px 0 20px;" />
                <div class="text-center mt-4" style="font-size:.83rem;color:var(--text-muted);">
                    <i class="bi bi-info-circle me-1"></i>Only administrators can access this page.
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>