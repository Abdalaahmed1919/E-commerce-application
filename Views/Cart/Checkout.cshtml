@model CheckOutViewModel
@{
    ViewData["Title"] = "Checkout";
}


<style>
    .page-header {
        background: var(--primary);
        color: #fff;
        padding: 36px 0;
    }

        .page-header h1 {
            font-family: 'Playfair Display',serif;
            font-size: 2rem;
        }

    .breadcrumb-item a {
        color: rgba(255,255,255,.6);
        text-decoration: none;
    }

    .breadcrumb-item.active {
        color: var(--accent);
    }

    .breadcrumb-item + .breadcrumb-item::before {
        color: rgba(255,255,255,.4);
    }
    .checkout-steps {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 32px;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .step-num {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .83rem;
        font-weight: 700;
    }

    .step.active .step-num {
        background: var(--accent);
        color: #fff;
    }

    .step.done .step-num {
        background: green;
        color: #fff;
    }

    .step.inactive .step-num {
        background: #ddd;
        color: #888;
    }

    .step-label {
        font-size: .88rem;
        font-weight: 500;
    }

    .step.inactive .step-label {
        color: #bbb;
    }

    .step-line {
        flex: 1;
        height: 2px;
        background: #e0e0e0;
        margin: 0 8px;
    }

        .step-line.done {
            background: green;
        }

    /* FORM SECTIONS */
    .form-section {
        background: #fff;
        border-radius: 12px;
        padding: 26px;
        border: 1px solid #ececec;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 18px;
        padding-bottom: 10px;
        border-bottom: 1px solid #ececec;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-label {
        font-size: .88rem;
        font-weight: 500;
        color: var(--primary);
        margin-bottom: 4px;
    }

    .form-control, .form-select {
        border: 1px solid #e0ddd8;
        border-radius: 7px;
        font-family: 'DM Sans',sans-serif;
        font-size: .9rem;
        padding: 10px 14px;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(233,69,96,.12);
        }

    /* PAYMENT */
    .payment-method {
        border: 2px solid #ececec;
        border-radius: 10px;
        padding: 14px 16px;
        cursor: pointer;
        transition: border-color .2s;
        margin-bottom: 10px;
    }

        .payment-method.selected {
            border-color: var(--accent);
            background: #fff8f9;
        }

        .payment-method label {
            cursor: pointer;
            font-weight: 500;
            font-size: .92rem;
        }

    /* ORDER SUMMARY */
    .order-summary {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        border: 1px solid #ececec;
        position: sticky;
        top: 90px;
    }

        .order-summary h5 {
            font-family: 'Playfair Display',serif;
            font-size: 1.2rem;
            border-bottom: 1px solid #ececec;
            padding-bottom: 12px;
            margin-bottom: 14px;
        }

    .mini-item {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .mini-img {
        width: 50px;
        height: 50px;
        background: #f0ede8;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .mini-name {
        font-size: .85rem;
        font-weight: 600;
    }

    .mini-price {
        font-size: .85rem;
        color: var(--accent);
        font-weight: 600;
        margin-left: auto;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: .9rem;
        margin-bottom: 8px;
    }

    .summary-total {
        font-size: 1.05rem;
        font-weight: 700;
        border-top: 2px solid #ececec;
        padding-top: 10px;
        margin-top: 4px;
    }

    .btn-place {
        background: var(--accent);
        color: #fff;
        border: none;
        width: 100%;
        padding: 13px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        transition: opacity .2s;
    }

        .btn-place:hover {
            opacity: .88;
        }
</style>

<div class="page-header">
    <div class="container">
        <h1>Checkout</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 mt-2">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Cart</a></li>
                <li class="breadcrumb-item active">Checkout</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="checkout-steps mb-4">
        <div class="step done"><div class="step-num"><i class="bi bi-check"></i></div><span class="step-label">Cart</span></div>
        <div class="step-line done"></div>
        <div class="step active"><div class="step-num">2</div><span class="step-label">Checkout</span></div>
        <div class="step-line"></div>
        <div class="step inactive"><div class="step-num">3</div><span class="step-label">Confirmation</span></div>
    </div>

    <form asp-controller="Cart" asp-action="PlaceOrder" method="post">

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="form-section">
                    <div class="form-section-title"><i class="bi bi-person"></i> Contact Information</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label">Full Name *</label>
                            <input asp-for="FullName" type="text" class="form-control" placeholder="John" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label">Phone Number *</label>
                            <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="+1 (555) 000-0000" />
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section-title"><i class="bi bi-geo-alt"></i> Shipping Address</div>
                    <div class="row g-3">

                        <div class="col-12">
                            <label asp-for="ShippingAddress" class="form-label">Address Line </label>
                            <input asp-for="ShippingAddress" type="text" class="form-control" placeholder="Apt, Suite, Floor (optional)" />
                            <span asp-validation-for="ShippingAddress"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="City" class="form-label">City *</label>
                            <input asp-for="City" type="text" class="form-control" placeholder="New York" />
                            <span asp-validation-for="City"></span>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section-title"><i class="bi bi-credit-card"></i> Payment Method</div>
                    <div class="payment-method selected">
                        <div class="form-check">
                            <input asp-for="PaymentMethod" class="form-check-input" type="radio" name="PaymentMethod" value="Visa" id="p1" checked />
                            <label  class="form-check-label" for="p1">💳 Credit / Debit Card</label>
                        </div>
                        <div class="mt-3 row g-3">
                            <div class="col-12">
                                <label class="form-label">Card Number *</label>
                                <input type="text" class="form-control" placeholder="1234 5678 9012 3426" maxlength="16" minlength="16" pattern="\d*" title="برجاء إدخال 16 رقم"  required/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Expiry Date *</label>
                                <input type="text" class="form-control" placeholder="MM / YY" maxlength="5" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">CVV *</label>
                                <input type="text" class="form-control" placeholder="123" maxlength="3" minlength="3" pattern="\d*" title="برجاء إدخال 3 أرقام" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Name on Card *</label>
                                <input type="text" class="form-control" placeholder="John Doe" required />
                            </div>
                        </div>
                    </div>
                    <div class="payment-method">
                        <div class="form-check">
                            <input asp-for="PaymentMethod" class="form-check-input" type="radio" name="PaymentMethod" value="Cash" id="p3" />
                            <label class="form-check-label" for="p3">💵 Cash on Delivery</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="order-summary">
                    <h5>Order Summary</h5>
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="mini-item">
                            <div><div class="mini-name">@item.Product.Name</div><div style="font-size:.75rem;color:var(--text-muted);"> Qty: @item.Quantity</div></div>
                            <span class="mini-price">
                                $@(item.Quantity* item.UnitPrice)
                            </span>
                        </div>
                    }
                    <hr style="border-color:#ececec;" />
                    <div class="summary-row summary-total"><span>Total</span><span style="color:var(--accent);">@Model.GrandTotal</span></div>

                    <button type="submit" class="btn-place mt-4">Place Order <i class="bi bi-lock ms-2"></i></button>

                    <div class="mt-2 text-center" style="font-size:.78rem;color:var(--text-muted);"><i class="bi bi-shield-check me-1"></i>256-bit SSL Secure Checkout</div>
                </div>
            </div>
        </div>

    </form>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {

            // 1. بنمسك المربعات بتاعت الفيزا اللي في الشاشة
            var visaInputs = $('#p1').closest('.payment-method').find('input[type="text"]');

            // 2. أول ما الصفحة تفتح، بنخليهم إجباري (Required) لأن الفيزا متعلم عليها افتراضياً
            visaInputs.prop('required', true);

            // 3. لما العميل يغير رأيه ويدوس على زراير الدفع
            $('input[name="PaymentMethod"]').change(function () {

                if ($(this).val() === 'Cash') {
                    // لو اختار كاش: بنشيل الإجبار عشان الفورم تتبعت بسلام
                    visaInputs.prop('required', false);
                }
                else {
                    // لو رجع اختار فيزا: بنرجع الإجبار تاني عشان ميبعتهاش فاضية
                    visaInputs.prop('required', true);
                }

            });

        });
    </script>
}